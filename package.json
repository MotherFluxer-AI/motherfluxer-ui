{
  "name": "motherfluxer-ui",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "pretest:infrastructure": "bash scripts/check-infrastructure.sh",
    "test:coverage": "jest --coverage",
    "test:watch": "jest --watch",
    "test:integration": "cross-env TEST_ENV=integration jest --config jest.config.integration.js",
    "test:infrastructure": "cross-env TEST_ENV=infrastructure jest --config jest.config.infrastructure.js"
  },
  "dependencies": {
    "dotenv": "16.4.0",
    "next": "14.2.24",
    "pg": "8.11.3",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "redis": "4.6.13",
    "socket.io-client": "4.7.0",
    "zustand": "4.5.0"
  },
  "devDependencies": {
    "@testing-library/dom": "10.4.0",
    "@testing-library/jest-dom": "6.4.0",
    "@testing-library/react": "14.2.0",
    "@testing-library/user-event": "14.5.0",
    "@types/jest": "29.5.12",
    "@types/node": "20.11.24",
    "@types/pg": "8.11.2",
    "@types/react": "18.2.61",
    "@types/react-dom": "18.2.19",
    "cross-env": "7.0.3",
    "jest": "29.7.0",
    "jest-environment-jsdom": "29.7.0",
    "msw": "1.3.2",
    "postcss": "8.4.35",
    "prettier": "3.2.0",
    "prettier-plugin-tailwindcss": "0.5.11",
    "tailwindcss": "3.4.1",
    "ts-jest": "29.1.1",
    "typescript": "5.2.2"
  }
}
