    "@testing-library/react": "^14.2.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "socket.io-client": "^4.7.0",
    "dotenv": "^16.4.0",
    "pg": "^8.11.3",
    "redis": "^4.6.13"
  },
  "devDependencies": {
    "typescript": "^5.3.3",
    "@types/node": "^20.11.24",
    "@types/jest": "^29.5.12",
    "@types/pg": "^8.11.2",
    "@types/react": "^18.2.61",
    "@types/react-dom": "^18.2.19",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.1",
    "prettier": "^3.2.0",
    "prettier-plugin-tailwindcss": "^0.5.11",
    "ts-jest": "^29.1.1",
